<?xml version="1.0" encoding="utf-8" ?>
<component name="SeriesDetailScreen" extends="Group">
  <interface>
    <field id="selectedSeries" type="assocarray" onChange="onSelectedSeriesChanged" />
    <field id="details" type="assocarray" onChange="onDetailsChanged" />
    <field id="loading" type="boolean" onChange="onLoadingChanged" />
    <field id="message" type="string" onChange="onMessageChanged" />
    <field id="backRequested" type="boolean" alwaysNotify="true" />
    <function name="setDetailFocus" />
  </interface>
  <script type="text/brightscript" uri="pkg:/components/SeriesDetailScreen.brs" />
  <children>
    <Rectangle width="1920" height="1080" color="0x071A33FF" />
    <Rectangle id="posterFallback" translation="[90,90]" width="300" height="450" color="0x18365FFF" />
    <Poster id="poster" translation="[90,90]" width="300" height="450" loadDisplayMode="scaleToFit" />
    <Label id="titleLabel" translation="[440,85]" width="1320" font="font:LargeBoldSystemFont" color="0xFFFFFFFF" />
    <Label id="metaLabel" translation="[440,150]" width="1320" font="font:MediumSystemFont" color="0xBBD6FFFF" />
    <Label id="descriptionLabel" translation="[440,205]" width="1320" height="150" wrap="true" font="font:MediumSystemFont" color="0xFFFFFFFF" />
    <Label text="TEMPORADAS" translation="[440,395]" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
    <LabelList id="seasonList" translation="[440,445]" itemSize="[160,52]" numRows="1" vertFocusAnimationStyle="fixedFocus" />
    <Label id="episodesTitleLabel" translation="[440,555]" width="1200" font="font:MediumBoldSystemFont" color="0xFFFFFFFF" />
    <LabelList id="episodeList" translation="[440,610]" itemSize="[1200,48]" numRows="6" />
    <BusySpinner id="spinner" translation="[900,930]" visible="false" />
    <Label id="messageLabel" translation="[440,930]" width="1200" horizAlign="center" font="font:MediumSystemFont" color="0xFFD36EFF" />
    <Label text="Player sera adicionado na PR 4." translation="[440,865]" width="1200" font="font:MediumSystemFont" color="0xBBD6FFFF" />
  </children>
</component>
